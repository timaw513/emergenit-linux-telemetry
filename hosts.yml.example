# hosts.yml — machines to audit
# Generated by: telem init
# Edit this file to add or remove hosts.
#
# local: true   = audit this machine directly (no SSH)
# local: false  = audit via SSH (key-based auth required)
#
# SSH setup for remote hosts:
#   ssh-keygen -t ed25519 -f ~/.ssh/telem_ed25519
#   ssh-copy-id -i ~/.ssh/telem_ed25519 user@remote-host

hosts:
  - name: localhost
    address: localhost
    user: user
    local: true

# Example remote host:
#  - name: web-server
#    address: 192.168.1.100
#    user: ubuntu
#    local: false
#    ssh_key: ~/.ssh/telem_ed25519
