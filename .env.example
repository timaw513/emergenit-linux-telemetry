# EmergenIT Linux Telemetry — environment template
# Copy to .env and run 'telem init' to auto-generate values
# OR fill in manually and run 'telem start'
# NEVER commit .env to git

# Hostname of this machine (auto-detected by telem init)
HOST_HOSTNAME=your-hostname

# InfluxDB
INFLUX_USER=admin
INFLUX_PASSWORD=change_me_strong_password
INFLUX_TOKEN=change_me_long_random_token_minimum_32_chars

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password
