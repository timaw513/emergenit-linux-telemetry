      "title": "Critical & High Findings (Latest Run)",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "PC59924CDF74A3ECD"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "severity"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "CRITICAL": {
                        "color": "red",
                        "index": 0
                      },
                      "HIGH": {
                        "color": "orange",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "rawQueryText": "SELECT f.test_id, f.severity, f.finding_type, f.category, f.description, f.solution FROM findings f JOIN audit_runs r ON f.run_id = r.id WHERE r.id = (SELECT id FROM audit_runs ORDER BY run_at DESC LIMIT 1) AND f.severity IN ('CRITICAL','HIGH') ORDER BY f.severity, f.test_id",
          "queryType": "table",
          "timeColumns": []
        }
      ]
