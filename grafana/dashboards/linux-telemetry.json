      "targets": [
        {
          "refId": "A",
          "query": "from(bucket:\"linux-metrics\") |> range(start:-10m) |> filter(fn:(r)=>r._measurement==\"cpu\" and r._field==\"usage_active\" and r.cpu==\"cpu-total\") |> last()"
