              }
            },
            {
              "type": "value",
              "options": {
                "0 1": {
                  "text": "NO",
                  "color": "red",
                  "index": 1
                }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "UNKNOWN",
                  "color": "orange",
                  "index": 2
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
