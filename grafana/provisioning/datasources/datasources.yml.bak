apiVersion: 1

datasources:
  - name: InfluxDB
    type: influxdb
    access: proxy
    url: http://influxdb:8086
    jsonData:
      version: Flux
      organization: emergenit
      defaultBucket: linux-metrics
    secureJsonData:
      token: ${INFLUX_TOKEN}
    isDefault: true
    editable: false

  - name: AuditDB
    type: frser-sqlite-datasource
    access: proxy
    jsonData:
      path: /data/audit.db
    editable: false
